{
  "name": "rodinka",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && npm run check:bundle",
    "build:analyze": "tsc -b && vite build --mode analyze && npm run check:bundle",
    "lint": "oxlint",
    "test": "vitest run",
    "test:db": "node scripts/run-db-authorization-tests.mjs",
    "check:edge-functions": "node scripts/check-edge-imports.mjs",
    "check:bundle": "node scripts/check-route-chunks.mjs",
    "audit:data-access": "node scripts/audit-data-access.mjs",
    "check:data-access": "node scripts/audit-data-access.mjs --check",
    "preview": "vite preview",
    "cap:copy": "npm run build && cap copy",
    "cap:sync": "npm run build && cap sync",
    "cap:android": "cap open android",
    "cap:ios": "cap open ios",
    "native:android": "npm run cap:sync && cap open android",
    "native:ios": "npm run cap:sync && cap open ios"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.2",
    "@capacitor/app": "^8.1.1",
    "@capacitor/browser": "^8.0.4",
    "@capacitor/core": "^8.4.2",
    "@capacitor/ios": "^8.4.2",
    "@capacitor/keyboard": "^8.0.5",
    "@capacitor/network": "^8.0.1",
    "@capacitor/push-notifications": "^8.1.2",
    "@capacitor/splash-screen": "^8.0.2",
    "@capacitor/status-bar": "^8.0.3",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource/manrope": "^5.2.8",
    "@supabase/supabase-js": "^2.110.2",
    "czech-vocative": "^2.1.0",
    "i18next": "^26.3.6",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.9"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "oxlint": "^1.71.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "sharp": "^0.35.3",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  }
}
